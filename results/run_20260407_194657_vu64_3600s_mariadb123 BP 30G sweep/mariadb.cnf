[mysqld]

# ─── General ───────────────────────────────────────────────────────────────────
user                            = mysql
datadir                         = /var/lib/mysql
socket                          = /var/run/mysqld/mysqld.sock
pid-file                        = /var/run/mysqld/mysqld.pid
bind-address                    = 0.0.0.0
port                            = 3306
skip-name-resolve               = ON
performance_schema              = OFF

# ─── Connection & Threading ────────────────────────────────────────────────────
max_connections                 = 2000
max_connect_errors              = 1000000
#thread_handling                 = pool-of-threads   # MariaDB thread pool
#thread_pool_size                = 64                # match physical core count
#thread_pool_max_threads         = 2000
thread_stack                    = 512K
thread_cache_size               = 256
back_log                        = 4096
wait_timeout                    = 300
interactive_timeout             = 300
connect_timeout                 = 10

# ─── InnoDB – Buffer Pool (60–70 % of RAM → ~80 GB) ───────────────────────────
innodb_buffer_pool_size         = 30G

# ─── InnoDB – I/O (NVMe can saturate many threads) ────────────────────────────
innodb_io_capacity              = 10000
innodb_io_capacity_max          = 20000
innodb_read_io_threads          = 16
innodb_write_io_threads         = 16
innodb_use_native_aio           = ON

# ─── InnoDB – Log / Durability ─────────────────────────────────────────────────
innodb_log_file_size            = 32G
innodb_log_buffer_size          = 256M
innodb_flush_log_at_trx_commit  = 1          # full ACID; use 2 for ~10 % more speed
innodb_doublewrite              = ON

innodb_data_file_buffering=OFF
innodb_data_file_write_through=OFF
innodb_log_file_buffering=ON
innodb_log_file_write_through=OFF

# ─── InnoDB – Concurrency & OLTP Tuning ───────────────────────────────────────
#innodb_adaptive_hash_index      = ON
#innodb_adaptive_flushing        = ON
#innodb_adaptive_flushing_lwm    = 10
#innodb_lru_scan_depth           = 4096
innodb_snapshot_isolation        = OFF
innodb_stats_on_metadata        = OFF
innodb_open_files               = 65536
innodb_lock_wait_timeout        = 50
innodb_rollback_on_timeout      = ON

#innodb_max_purge_lag = 100000
#innodb_max_purge_lag_delay = 1000000
#innodb_purge_threads            = 1
#innodb_purge_batch_size         = 10



# ─── InnoDB – Redo / Purge ─────────────────────────────────────────────────────

# ─── Query Cache (disabled – harmful at high concurrency) ─────────────────────
query_cache_type                = OFF
query_cache_size                = 0

# ─── Per-Session Buffers (keep modest; many connections × this = RAM) ──────────
sort_buffer_size                = 4M
join_buffer_size                = 4M
read_buffer_size                = 2M
read_rnd_buffer_size            = 4M
tmp_table_size                  = 256M
max_heap_table_size             = 256M

# ─── Table & File Handles ──────────────────────────────────────────────────────
table_open_cache                = 65536
table_definition_cache          = 65536
open_files_limit                = 1000000

# ─── Binary Log (enable for replication / PITR) ────────────────────────────────
log_bin                         = /var/lib/mysql/mysql-bin
binlog_format                   = ROW
binlog_row_image                = MINIMAL
expire_logs_days                = 7
sync_binlog                     = 1
binlog_cache_size               = 4M
max_binlog_size                 = 512M

# ─── Slow Query Log ────────────────────────────────────────────────────────────
slow_query_log                  = ON
slow_query_log_file             = /var/lib/mysql/slow.log
long_query_time                 = 1
log_queries_not_using_indexes   = OFF
min_examined_row_limit          = 1000

# ─── Character Set ─────────────────────────────────────────────────────────────
character_set_server            = utf8mb4
collation_server                = utf8mb4_unicode_ci

# ─── Misc ──────────────────────────────────────────────────────────────────────
max_allowed_packet              = 64M
bulk_insert_buffer_size         = 256M
myisam_sort_buffer_size         = 128M
key_buffer_size                 = 64M        # MyISAM only; keep small for OLTP

[mysqldump]
quick
max_allowed_packet              = 64M

[client]
socket                          = /var/run/mysqld/mysqld.sock
default-character-set           = utf8mb4

